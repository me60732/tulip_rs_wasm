{
  "name": "tulip-rs-wasm",
  "version": "0.1.11",
  "description": "WebAssembly bindings for tulip_rs — Technical Analysis Library for browsers",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/me60732/tulip_rs_wasm.git"
  },
  "scripts": {
    "build": "wasm-pack build --target bundler --out-dir pkg && tsc",
    "build:web": "wasm-pack build --target web --out-dir pkg && tsc",
    "build:debug": "wasm-pack build --dev --target bundler --out-dir pkg && tsc",
    "build:wasm": "wasm-pack build --target bundler --out-dir pkg",
    "build:wasm:web": "wasm-pack build --target web --out-dir pkg",
    "build:ts": "tsc",
    "test": "wasm-pack test --headless --chrome"
  },
  "devDependencies": {
    "playwright": "1.60.0",
    "typescript": "5.9.3",
    "wasm-pack": "0.15.0"
  },
  "files": [
    "pkg/tulip_rs_wasm_bg.wasm",
    "pkg/tulip_rs_wasm_bg.wasm.d.ts",
    "pkg/tulip_rs_wasm.js",
    "pkg/tulip_rs_wasm.d.ts",
    "index.js",
    "index.d.ts",
    "src-ts/indicator.js",
    "src-ts/indicator.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  }
}
